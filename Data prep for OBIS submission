#Link DNA sequences from otu_df

dna_df <- dna_df %>%
  left_join(
    otu_df %>%
      select(
        scientificName,
        seq_id = otu_id,
        dna_sequence = sequence
      ),
    relationship = "many-to-many"
  )

dna_df <- dna_df %>%
  select(
    occurrenceID, samp_name, project_name, scientificName, env_broad_scale, env_local_scale,
    env_medium, samp_mat_process, size_frac, samp_size, target_gene, target_subfragment, seq_meth,
    ref_db, otu_seq_comp_appr, otu_db, pcr_primer_forward, pcr_primer_reverse, pcr_primer_name_forward,
    pcr_primer_name_reverse, pcr_primer_reference, extension, seq_id, dna_sequence
  )


