    target_gene = target_gene,
    target_subfragment = target_subfragment,
    seq_meth = "Illumina MiSeq [OBI_0002003]",
    ref_db = "MitoFish [Iwasaki et al., 2013; Sato et al., 2018; Zhu et al., 2023]",
    otu_seq_comp_appr = "[vsearch](https://github.com/torognes/vsearch/releases) v2.14.2+",
    otu_db = "barque v1.7.2 (Mathon et al. (2021))",
    pcr_primer_forward = "CGTGCCAGCCACCGCGGTT",
    pcr_primer_reverse = "CATAGTGGGGTATCTAATCCCAGTTTG",
    pcr_primer_name_forward = "12S_248F_RADS_For",
