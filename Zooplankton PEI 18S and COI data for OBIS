#Look up AphiaID (taxonID) from WoRMS by ScientificName

species_lookup <- occurrence %>%
  distinct(scientificName) %>%
  mutate(
    taxonID = map_int(
      scientificName,
      ~ {
        # Keep NAs as NAs
        if (is.na(.x) || .x == "") return(NA_integer_)

        id <- tryCatch(
          wm_name2id(.x, marine_only = FALSE),
          error = function(e) NA
        )

        if (is.null(id) || length(id) == 0 || is.na(id[1])) {
          NA_integer_
        } else {
          as.integer(id[1])
        }
      }
    )
  )

