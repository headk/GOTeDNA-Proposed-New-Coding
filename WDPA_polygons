mpa_marine <- mpa_all %>%
  filter(
    REALM == "Marine",
    STATUS == "Designated"
  )

# Transform to WGS84
mpa_marine_wgs84 <- st_transform(mpa_marine, 4326)

# Map
leaflet(mpa_marine_wgs84) %>%
  addProviderTiles("Esri.OceanBasemap") %>%
  addPolygons(
    weight = 2,
    fillOpacity = 0.5,
    popup = ~NAME_ENG
  )

