library(sf)
library(dplyr)
library(stringr)
library(leaflet)

wdpa_path <- "C:/Users/HEADK/Desktop/WDPA_May2026_Public_shp.zip"
wdpa_dir  <- "C:/Users/HEADK/Desktop/WDPA_May2026_Public_shp"

# Unzip main WDPA zip
unzip(wdpa_path, exdir = wdpa_dir)

# Unzip the split shapefile zip files
nested_zips <- list.files(
  wdpa_dir,
  pattern = "\\.zip$",
  full.names = TRUE
)

for (z in nested_zips) {
  unzip(z, exdir = wdpa_dir)
}

# Find shapefiles
shps <- list.files(
  wdpa_dir,
  pattern = "\\.shp$",
  recursive = TRUE,
  full.names = TRUE
)

shps

polygon_shp <- "C:/Users/HEADK/Desktop/WDPA_May2026_Public_shp/WDPA_May2026_Public_shp-polygons.shp"

mpa_all <- st_read(polygon_shp)

#names(mpa_all)

mpa_marine <- mpa_all %>%
  filter(
    REALM == "Marine",
    STATUS == "Designated",
    ISO3 != "CAN",
    str_detect(
      DESIG_ENG,
      regex(
        "Protected|Reserve|Marine Park|Refuge",
        ignore_case = TRUE
      )
    )
  )


# Export shapefile
st_write(
  mpa_marine,
  "C:/Users/HEADK/Desktop/mpa_marine.shp",
  delete_layer = TRUE
)

st_write(
  mpa_marine,
  "C:/Users/HEADK/Desktop/mpa_marine.gpkg",
  delete_dsn = TRUE
)

#simpler shapefiles

library(rmapshaper)

mpa_simple <- ms_simplify(
  mpa_marine,
  keep = 0.05,
  keep_shapes = TRUE
)

st_write(
  mpa_simple,
  "C:/Users/HEADK/Desktop/mpa_marine.gpkg",
  delete_dsn = TRUE
)


# Transform to WGS84
mpa_marine_wgs84 <- st_transform(mpa_simple, 4326)

# Map
leaflet(mpa_marine_wgs84) %>%
  addProviderTiles("Esri.OceanBasemap") %>%
  addPolygons(
    weight = 2,
    fillOpacity = 0.5,
    popup = ~NAME_ENG
  )

