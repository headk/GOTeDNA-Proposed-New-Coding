#Clean up the species column to just show genus species
barq <- barq %>%
  mutate(
    TaxonName = str_split(TaxonName, "_") |>
      purrr::map_chr(~ paste(tail(.x, 2), collapse = " "))
  )


erin <- erin %>%
  mutate(
    Species = Species %>%
      as.character() %>%
      str_replace_all("\u00A0", " ") %>%                 # NBSP -> normal space
      str_squish() %>%
      str_replace_all("_", " ") %>%

      # remove many bracket types, not just [ ]
      str_replace_all("[\\[\\]［］【】〔〕〈〉《》\\(\\){}]", "") %>%

      # remove sp. / cf. / aff. (optional)
      str_remove_all("\\b(sp|cf|aff)\\.?\\b") %>%
      str_squish() %>%

      # if it looks like "Genus 188466 ..." keep genus only
      if_else(str_detect(., "^[A-Z][a-z]+\\s+\\d+\\b"),
              str_extract(., "^[A-Z][a-z]+"),
              .) %>%

      # remove ANY trailing tokens that contain digits (kills "CMC01", "604195", etc.)
      str_remove("\\s+(\\S*\\d\\S*)(\\s+\\S*\\d\\S*)*$") %>%
      str_squish()
  )


