### filtering SAR and AIS from OBIS-GOTeDNA format
#Get list of Red list species names and keep only rows for those species in main dataframe

ds_id <- "3caeb629-da2d-4c1a-8a2e-1fbf39174cfa"

# Species checklist limited to IUCN Red List taxa
rl_species <- robis::checklist(datasetid = ds_id, redlist = TRUE) %>%
  distinct(scientificName) %>%
  arrange(scientificName)

# If you already built `coreandextensions_filtered`, keep only rows for those species:
coreandextensions_redlist <- coreandextensions_filtered %>%
  semi_join(rl_species, by = "scientificName")

