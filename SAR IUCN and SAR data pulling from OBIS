View(rl_species) #This is to tell you which species are redlisted in your dataset

# Get all historic and latest assessments for each species (not case-sensitive)
redlist_sp1 <- assessments_by_name(api, genus = "Balistes", species = "capriscus")
redlist_sp2 <- assessments_by_name(api, genus = "Hyporthodus", species = "flavolimbatus")
redlist_sp3 <- assessments_by_name(api, genus = "Lopholatilus", species = "chamaeleonticeps")
redlist_sp4 <- assessments_by_name(api, genus = "Lutjanus", species = "campechanus")

redlist_all <- bind_rows(
  redlist_sp1,
  redlist_sp2,
  redlist_sp3,
  redlist_sp4
)

# Filter by the most recent listing and for global category status, as done by the UNESCO eDNA dashboard
redlist_all <- redlist_all %>%
  filter(latest == TRUE, scopes_description_en == "Global")

coreandextensions_redlist_cat <- left_join(coreandextensions_redlist, redlist_all, by = c("scientificName" = "taxon_scientific_name"))
