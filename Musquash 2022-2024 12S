# 1) Build species → AphiaID lookup
species_lookup <- tibble::tibble(
  scientificName = unique(df_Musq12S$scientificName)
) %>%
  mutate(
    taxonID = sapply(scientificName, function(s) {
      id <- tryCatch(
        wm_name2id(s, marine_only = FALSE),
        error = function(e) NA
      )
      if (is.null(id) || length(id) == 0) NA_integer_ else as.integer(id[1])
    })
  )

