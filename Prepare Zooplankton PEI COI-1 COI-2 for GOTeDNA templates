# 1) Build TaxonName → AphiaID lookup
TaxonName_lookup <- tibble::tibble(
  scientificName = unique(df_COI1$scientificName)
) %>%
  mutate(
    taxonID = sapply(scientificName, function(s) {
      id <- tryCatch(
        wm_name2id(s, marine_only = FALSE),
        error = function(e) NA
      )
      if (is.null(id) || length(id) == 0) NA_integer_ else as.integer(id[1])
    })
  )

# 2) Join AphiaIDs and replace NA with empty string
df_COI1 <- df_COI1 %>%
  select(-any_of("taxonID")) %>%
  left_join(TaxonName_lookup, by = "scientificName") %>%
  mutate(
    taxonID = if_else(
      is.na(taxonID),
      "",
      as.character(taxonID)
    )
  )

# Safe extractor for a given rank using the 'scientificname' column
library(dplyr)
library(purrr)
library(stringr)
library(tibble)
library(worrms)

# Safe extractor
.rank_val <- function(classif, rank_name) {
  if (is.null(classif)) return(NA_character_)
  if (!all(c("rank","scientificname") %in% names(classif))) return(NA_character_)
  v <- classif$scientificname[classif$rank == rank_name]
  if (length(v) == 0) NA_character_ else as.character(v[1])
}

get_taxonomy_for_id <- function(id) {
  # guard against blanks / non-numeric ids
  if (is.na(id) || id == "" || !str_detect(id, "^[0-9]+$")) {
    return(tibble(
      taxonID = as.character(id),
      kingdom = NA_character_, phylum = NA_character_, class = NA_character_,
      order = NA_character_, family = NA_character_, genus = NA_character_
    ))
  }

  classif <- tryCatch(wm_classification(as.integer(id)), error = function(e) NULL)

  tibble(
    taxonID = as.character(id),
    kingdom = .rank_val(classif, "Kingdom"),
    phylum  = .rank_val(classif, "Phylum"),
    class   = .rank_val(classif, "Class"),
    order   = .rank_val(classif, "Order"),
    family  = .rank_val(classif, "Family"),
    genus   = .rank_val(classif, "Genus")
  )
}

# Build taxonomy lookup ONLY for real AphiaIDs
unique_ids <- df_COI1 %>%
  distinct(taxonID) %>%
  filter(!is.na(taxonID), taxonID != "", str_detect(taxonID, "^[0-9]+$")) %>%
  pull(taxonID)

taxonomy_lookup <- map_dfr(unique_ids, get_taxonomy_for_id)

# Join back (keep blanks for non-matches)
df_COI1 <- df_COI1 %>%
  mutate(taxonID = as.character(taxonID)) %>%
  select(-any_of(c("kingdom","phylum","class","order","family","genus"))) %>%
  left_join(taxonomy_lookup, by = "taxonID") %>%
  mutate(across(c(kingdom, phylum, class, order, family, genus), ~replace_na(.x, "")))


